{
  "name": "mpho",
  "private": true,
  "scripts": {
    "dev:customer": "pnpm --filter @mpho/customer dev",
    "dev:partner": "pnpm --filter @mpho/partner dev",
    "dev:central": "pnpm --filter @mpho/central dev",
    "dev": "pnpm run --parallel dev:customer dev:partner dev:central",
    "build": "pnpm --filter './apps/*' build",
    "build:customer": "pnpm --filter @mpho/customer build",
    "build:partner": "pnpm --filter @mpho/partner build",
    "build:central": "pnpm --filter @mpho/central build",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:test": "supabase test db",
    "db:test:rest": "sh scripts/test-public-catalog-rest.sh && sh scripts/test-quotes-rest.sh",
    "db:types": "sh scripts/generate-database-types.sh",
    "db:types:check": "sh scripts/check-database-types.sh",
    "db:schema:check": "sh scripts/check-schema-drift.sh",
    "security:check": "sh scripts/check-client-secrets.sh",
    "format": "prettier --write \"**/*.{ts,tsx,css,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,css,json,md}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/node": "^24",
    "eslint": "^9.39.0",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.5.0",
    "supabase": "^2.62.10",
    "typescript": "5.7.3",
    "typescript-eslint": "^8.46.0",
    "vitest": "^3.2.0"
  }
}
