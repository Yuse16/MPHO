{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "target": "ES6",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@mpho/design-tokens": [
        "../../packages/design-tokens"
      ],
      "@mpho/types": [
        "../../packages/types"
      ],
      "@mpho/validation": [
        "../../packages/validation"
      ],
      "@mpho/config": [
        "../../packages/config"
      ],
      "@mpho/database": [
        "../../packages/database"
      ],
      "@mpho/database/client": [
        "../../packages/database/client"
      ],
      "@mpho/database/types": [
        "../../packages/database/types"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
