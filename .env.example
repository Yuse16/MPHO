# ===========================================
# MPHO — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local or any file with real secrets.

# Base URL (used for canonical links and redirects)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Supabase (Phase 2+)
# ─────────────────────────────────────────────
# Local development (supabase start)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Production (never commit real values)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Mercado Pago Checkout Pro (Phase 8, server-only secrets)
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_ENVIRONMENT=test
MERCADO_PAGO_APPLICATION_ID=
MERCADO_PAGO_NOTIFICATION_URL=https://example.invalid/api/webhooks/mercado-pago
CUSTOMER_APP_BASE_URL=https://example.invalid
PAYMENT_CHECKOUT_MIN_REMAINING_SECONDS=600
PAYMENT_PROVIDER_TIMEOUT_MS=8000

# WhatsApp Business (Phase 3+)
# WHATSAPP_API_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# n8n Webhooks (Phase 3+)
# N8N_WEBHOOK_URL=
# N8N_WEBHOOK_SECRET=

# Vercel (deployment)
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
